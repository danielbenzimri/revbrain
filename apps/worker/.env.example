# ============================================================
# CPQ Extraction Worker — Environment Variables
# ============================================================
# Copy to .env.local and fill in values for local development.
# In production, these are injected by Cloud Secret Manager.
# ============================================================

# --- Required: Job identity (from Cloud Run override) ---
JOB_ID=local-test
RUN_ID=00000000-0000-0000-0000-000000000000

# --- Required: Database (scoped to extractor_worker role) ---
# Must use sslmode=require for direct connections
DATABASE_URL=postgresql://extractor_worker:password@localhost:54322/postgres?sslmode=disable

# --- Required: Salesforce token encryption ---
# 32-byte key as base64. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SALESFORCE_TOKEN_ENCRYPTION_KEY=

# --- Required: Supabase Storage ---
SUPABASE_STORAGE_URL=http://localhost:54321/storage/v1
SUPABASE_SERVICE_ROLE_KEY=

# --- Required: Internal API (token refresh delegation) ---
INTERNAL_API_URL=http://localhost:3000/v1
INTERNAL_API_SECRET=dev-internal-secret

# --- Optional ---
TRACE_ID=local-trace-001
LOG_LEVEL=debug
WORKER_VERSION=dev

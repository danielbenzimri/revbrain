{
  "name": "@revbrain/migration-ir-contract",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Pure-type contract package for the BB-3 Migration IR Normalizer. Zero native deps — safe to import from Deno edge functions.",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "tsc --noEmit",
    "check:no-native-deps": "node ../../scripts/check-no-native-deps.mjs @revbrain/migration-ir-contract"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  }
}

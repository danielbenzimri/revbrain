{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Agent Message",
  "type": "object",
  "properties": {
    "from": {
      "type": "string"
    },
    "to": {
      "type": "string"
    },
    "ticketId": {
      "type": "string"
    },
    "content": {
      "type": "string"
    },
    "timestamp": {
      "type": "integer"
    }
  },
  "required": ["from", "to", "content", "timestamp"]
}

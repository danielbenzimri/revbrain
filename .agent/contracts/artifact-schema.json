{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Agent Artifact",
  "type": "object",
  "properties": {
    "agentId": {
      "type": "string"
    },
    "type": {
      "enum": ["code", "plan", "report", "log"]
    },
    "path": {
      "type": "string"
    },
    "checksum": {
      "type": "string"
    }
  },
  "required": ["agentId", "type", "path"]
}

# ==============================================
# REVBRAIN — Environment Files
#
# Copy the appropriate template and fill in values:
#
# .env.local  → pnpm local  (mock mode, no external services)
# .env.stg    → pnpm dev    (local server against staging Supabase)
# .env.prod   → production  (edge functions + Vercel)
#
# Commands:
#   pnpm local      → Frontend + Server, mock mode (offline)
#   pnpm dev        → Frontend + Server, staging Supabase DB
#   pnpm dev:remote → Frontend only, staging Edge Function backend
#   pnpm stg        → Alias for dev:remote
# ==============================================

# --- For .env.stg (staging) ---
NODE_ENV=development
APP_ENV=staging
USE_MOCK_DATA=false
AUTH_MODE=jwt

DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-1-[region].pooler.supabase.com:6543/postgres

SUPABASE_URL=https://[ref].supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
SUPABASE_PROJECT_ID=your-project-ref

VITE_API_URL=http://localhost:3000
VITE_SUPABASE_URL=https://[ref].supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_AUTH_MODE=jwt

FRONTEND_URL=http://localhost:5173
APP_URL=http://localhost:5173

RESEND_API_KEY=
EMAIL_FROM=RevBrain <noreply@revbrain.ai>

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
VITE_STRIPE_PUBLISHABLE_KEY=

# ==============================================
# DEV REMOTE ENVIRONMENT
#
# Copy to .env.dev to use with: pnpm dev:remote
# This runs the client locally, pointing at the
# remote Supabase dev environment (Edge Functions + DB).
#
# Ask the project owner for the actual values.
# ==============================================

NODE_ENV=development

# ---------------------------------------------
# CLIENT-SIDE (required for dev:remote)
# These are public/safe keys (anon key + publishable)
# ---------------------------------------------
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_API_URL=https://your-project.supabase.co/functions/v1/api
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx

# ---------------------------------------------
# FRONTEND URL (for redirects)
# ---------------------------------------------
FRONTEND_URL=http://localhost:5173

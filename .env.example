# ==============================================
# REVBRAIN ENVIRONMENT TEMPLATE
#
# Single source of truth for all configuration.
# Copy to .env.local, .env.dev, or .env.prod
#
# ┌─────────┬────────────────────────────┬─────────────────────────┐
# │ Env     │ Server                     │ Database                │
# ├─────────┼────────────────────────────┼─────────────────────────┤
# │ LOCAL   │ Local Hono (pnpm dev)      │ Local Docker Postgres   │
# │ DEV     │ Supabase Edge Functions    │ Supabase Dev Postgres   │
# │ PROD    │ Supabase Edge Functions    │ Supabase Prod Postgres  │
# └─────────┴────────────────────────────┴─────────────────────────┘
# ==============================================

NODE_ENV=development

# ---------------------------------------------
# DATABASE
# LOCAL:  postgresql://postgres:postgres@localhost:5432/revbrain
# REMOTE: postgresql://postgres.{project}:{password}@pooler.supabase.com:6543/postgres
# ---------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/revbrain

# ---------------------------------------------
# SUPABASE
# Get from: Supabase Dashboard > Settings > API
# ---------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Client-side (VITE_ prefix required for Vite)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ---------------------------------------------
# API URL (Client → Server)
# LOCAL: http://localhost:3000
# DEV:   https://{project}.supabase.co/functions/v1/api
# ---------------------------------------------
VITE_API_URL=http://localhost:3000

# ---------------------------------------------
# FRONTEND URL (Server → Client redirects)
# LOCAL: http://localhost:5173
# STG:   https://stg.revbrain.com
# PROD:  https://app.revbrain.com
# ---------------------------------------------
FRONTEND_URL=http://localhost:5173

# ---------------------------------------------
# APP URL (used for email links and redirects)
# LOCAL: http://localhost:5173
# STG:   https://stg.revbrain.com
# PROD:  https://app.revbrain.com
# ---------------------------------------------
APP_URL=http://localhost:5173

# ---------------------------------------------
# CORS ORIGINS (comma-separated, server only)
# Used by Supabase Edge Functions. Local dev uses defaults from code.
# STG:  https://stg.revbrain.com,https://revbrain.com,http://localhost:5173
# PROD: https://app.revbrain.com,https://revbrain.com
# ---------------------------------------------
# CORS_ORIGINS=

# ---------------------------------------------
# EMAIL (Resend)
# Leave RESEND_API_KEY empty for console output
# ---------------------------------------------
RESEND_API_KEY=
EMAIL_FROM=RevBrain <noreply@revbrain.com>

# ---------------------------------------------
# STRIPE
# Test keys: sk_test_xxx, pk_test_xxx
# Live keys: sk_live_xxx, pk_live_xxx
# ---------------------------------------------
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx

# ---------------------------------------------
# CLI TOOLS (Supabase CLI, Vercel CLI)
# ---------------------------------------------
SUPABASE_ACCESS_TOKEN=your-supabase-access-token
SUPABASE_PROJECT_ID_DEV=your-dev-project-id
SUPABASE_PROJECT_ID_PROD=your-prod-project-id
DB_PASSWORD=your-db-password

VERCEL_TOKEN=your-vercel-token
VERCEL_PROJECT_ID=your-vercel-project-id
VERCEL_ORG_ID=your-vercel-org-id

# ---------------------------------------------
# SENTRY (Error Tracking)
# Get from: sentry.io > Project Settings > Client Keys
# ---------------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=

# ---------------------------------------------
# ALERTING
# Channels: Console (always on), Email, Slack, Sentry
# ---------------------------------------------
# Email alerts (comma-separated recipients)
ALERT_EMAIL_RECIPIENTS=
# Override recipients for critical-only alerts
ALERT_CRITICAL_RECIPIENTS=
# Slack incoming webhook URL (from slack.com/apps)
SLACK_ALERT_WEBHOOK_URL=

# ---------------------------------------------
# DXF PARSER (Python/ezdxf service on Vercel)
# Optional: Falls back to TypeScript parser if not configured
# ---------------------------------------------
# URL of the Python DXF parser service
DXF_PARSER_URL=
# API key for authenticating with the DXF parser service
DXF_PARSER_API_KEY=
# Client-side URL (if using direct client calls)
VITE_DXF_PARSER_URL=

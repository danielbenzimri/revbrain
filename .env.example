# =============================================================================
# RevBrain — Environment Variables
# =============================================================================
#
# Three development modes:
#
#   pnpm dev            →  Mock mode (offline, no credentials needed)
#                           Uses .env.mock (committed to repo, works out of the box)
#
#   pnpm dev:stg        →  Staging mode (local server + client against staging Supabase)
#                           Copy this file to .env.staging and fill in real credentials
#
#   pnpm dev:stg-remote →  Staging remote (client-only against deployed edge functions)
#                           Copy this file to .env.staging.remote and fill in VITE_* vars
#
# .env.staging and .env.staging.remote are gitignored.
# .env.mock is committed (zero secrets).
# Ask the project owner for staging credentials.
# =============================================================================

# --- Mode ---
NODE_ENV=development               # development | production
APP_MODE=staging                   # mock | staging | staging-remote
USE_MOCK_DATA=false                # true = mock mode (pnpm dev)
AUTH_MODE=jwt                      # mock | jwt
VITE_AUTH_MODE=jwt                 # mock | jwt

# --- Database (Supabase Pooler) ---
DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-1-[region].pooler.supabase.com:6543/postgres

# --- Supabase ---
SUPABASE_URL=https://[ref].supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
SUPABASE_PROJECT_ID=your-project-ref

# --- Client (VITE_ prefix — exposed to browser, public keys only) ---
VITE_API_URL=http://localhost:3000
VITE_SUPABASE_URL=https://[ref].supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# --- URLs ---
FRONTEND_URL=http://localhost:5173
APP_URL=http://localhost:5173

# --- Email (Resend) ---
RESEND_API_KEY=
EMAIL_FROM=RevBrain <noreply@revbrain.ai>

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
VITE_STRIPE_PUBLISHABLE_KEY=

# --- Sentry (optional) ---
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# --- Alerting (optional) ---
SLACK_ALERT_WEBHOOK_URL=
ALERT_EMAIL_RECIPIENTS=

# --- Salesforce Integration ---
SALESFORCE_CONSUMER_KEY=                    # ECA Consumer Key (client_id)
SALESFORCE_CONSUMER_SECRET=                 # ECA Consumer Secret (client_secret)
SALESFORCE_TOKEN_ENCRYPTION_KEY=            # 32-byte base64 key for AES-256-GCM (openssl rand -base64 32)
SALESFORCE_STATE_SIGNING_SECRET=            # Secret for signing OAuth state JWTs (openssl rand -base64 32)
SALESFORCE_CALLBACK_URL=http://localhost:5173/api/v1/salesforce/oauth/callback

# --- Worker (for CPQ assessment jobs) ---
WORKER_SECRET=                              # Shared secret for worker ↔ control plane auth (openssl rand -base64 32)

# --- Persona Quick-Login (staging only, server-side) ---
# Server-side secret gates the /v1/dev/persona-login endpoint.
# NOT prefixed with VITE_ — never exposed to client code.
PERSONA_LOGIN_SECRET=                       # openssl rand -base64 32
# Client-side flag — tells the UI to show the persona picker.
VITE_PERSONA_LOGIN_ENABLED=true

# =============================================================================
# RevBrain — Environment Variables
# =============================================================================
#
# Copy to the appropriate file:
#
#   .env.local  →  pnpm local   (mock mode, offline, no external services)
#   .env.stg    →  pnpm dev     (local server against staging Supabase)
#   .env.prod   →  production   (edge functions + Vercel)
#
# .env.local, .env.stg, .env.prod are gitignored.
# Ask the project owner for staging/production credentials.
# =============================================================================

# --- Mode ---
NODE_ENV=development               # development | production
APP_ENV=staging                    # local | staging | production
USE_MOCK_DATA=false                # true = mock mode (pnpm local)
AUTH_MODE=jwt                      # mock | jwt

# --- Database (Supabase Pooler) ---
DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-1-[region].pooler.supabase.com:6543/postgres

# --- Supabase ---
SUPABASE_URL=https://[ref].supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
SUPABASE_PROJECT_ID=your-project-ref

# --- Client (VITE_ prefix — exposed to browser, public keys only) ---
VITE_API_URL=http://localhost:3000
VITE_SUPABASE_URL=https://[ref].supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_AUTH_MODE=jwt                 # mock | jwt

# --- URLs ---
FRONTEND_URL=http://localhost:5173
APP_URL=http://localhost:5173

# --- Email (Resend) ---
RESEND_API_KEY=
EMAIL_FROM=RevBrain <noreply@revbrain.ai>

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
VITE_STRIPE_PUBLISHABLE_KEY=

# --- Sentry (optional) ---
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# --- Alerting (optional) ---
SLACK_ALERT_WEBHOOK_URL=
ALERT_EMAIL_RECIPIENTS=
